{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Sogo DB Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--disable-extensions",
				"--extensionDevelopmentPath=${workspaceFolder}/packages/extension",
				"${workspaceFolder}/packages/extension/test-workspace"
			],
			"outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"],
			"preLaunchTask": "build-extension"
		}
	]
}
