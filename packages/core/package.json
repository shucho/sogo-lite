{
	"name": "sogo-db-core",
	"version": "0.2.0",
	"description": "Core types and utilities for Sogo DB — Notion-style databases as .db.json files",
	"type": "module",
	"license": "MIT",
	"author": "DataRM",
	"repository": {
		"type": "git",
		"url": "https://github.com/shucho/sogo-db.git",
		"directory": "packages/core"
	},
	"homepage": "https://github.com/shucho/sogo-db#readme",
	"keywords": [
		"database",
		"notion",
		"json",
		"schema",
		"records",
		"csv",
		"migration"
	],
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^22.19.13",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
