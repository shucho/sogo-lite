{
	"name": "sogo-mcp-server",
	"version": "0.2.0",
	"description": "MCP server for Sogo DB — AI agent access to Notion-style .db.json databases",
	"type": "module",
	"license": "MIT",
	"author": "DataRM",
	"repository": {
		"type": "git",
		"url": "https://github.com/shucho/sogo-db.git",
		"directory": "packages/mcp-server"
	},
	"homepage": "https://github.com/shucho/sogo-db#readme",
	"keywords": [
		"mcp",
		"model-context-protocol",
		"database",
		"notion",
		"ai",
		"agent",
		"claude"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"sogo-mcp-server": "bin/sogo-mcp-server.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist", "bin"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"lint": "tsc --noEmit"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"sogo-db-core": "workspace:*",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
