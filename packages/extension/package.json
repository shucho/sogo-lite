{
	"name": "sogo-lite",
	"displayName": "Sogo Lite",
	"description": "Notion-style databases in VS Code — view and edit .db.json files as tables, kanbans, calendars, and more",
	"version": "0.2.1",
	"publisher": "shucho",
	"license": "MIT",
	"author": "DataRM",
	"repository": {
		"type": "git",
		"url": "https://github.com/shucho/sogo-db.git",
		"directory": "packages/extension"
	},
	"homepage": "https://github.com/shucho/sogo-db#readme",
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#1a1a2e",
		"theme": "dark"
	},
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": [
		"Other",
		"Visualization"
	],
	"keywords": [
		"database",
		"notion",
		"kanban",
		"table",
		"json",
		"calendar",
		"gallery"
	],
	"main": "./dist/extension.js",
	"scripts": {
		"build": "node esbuild.mjs",
		"dev": "node esbuild.mjs --watch",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
		"lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.webview.json --noEmit",
		"test": "vitest run --passWithNoTests",
		"package": "vsce package --no-dependencies",
		"publish": "vsce publish --no-dependencies"
	},
	"contributes": {
		"customEditors": [
			{
				"viewType": "sogo-db.databaseEditor",
				"displayName": "Sogo Database Editor",
				"selector": [
					{
						"filenamePattern": "*.db.json"
					}
				],
				"priority": "default"
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "sogo-db",
					"title": "Databases",
					"icon": "$(database)"
				}
			]
		},
		"views": {
			"sogo-db": [
				{
					"id": "sogo-db.databaseList",
					"name": "Databases",
					"type": "webview"
				}
			]
		},
		"commands": [
			{
				"command": "sogo-db.createDatabase",
				"title": "Sogo DB: Create Database"
			},
			{
				"command": "sogo-db.deleteDatabase",
				"title": "Sogo DB: Delete Database"
			},
			{
				"command": "sogo-db.duplicateDatabase",
				"title": "Sogo DB: Duplicate Database"
			},
			{
				"command": "sogo-db.exportCsv",
				"title": "Sogo DB: Export to CSV"
			},
			{
				"command": "sogo-db.importCsv",
				"title": "Sogo DB: Import from CSV"
			},
			{
				"command": "sogo-db.openAsJson",
				"title": "Sogo DB: Open as JSON"
			},
			{
				"command": "sogo-db.refresh",
				"title": "Sogo DB: Refresh Databases",
				"icon": "$(refresh)"
			}
		],
		"configuration": {
			"title": "Sogo DB",
			"properties": {
				"sogo-db.globalPaths": {
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional directories to scan for global databases (besides ~/.sogo/globalDatabases/)"
				},
				"sogo-db.scanDepth": {
					"type": "number",
					"default": 3,
					"minimum": 1,
					"maximum": 10,
					"description": "Maximum directory depth to scan for .db.json files in workspaces"
				},
				"sogo-db.autoStartMcpServer": {
					"type": "boolean",
					"default": false,
					"description": "Automatically start the sogo-mcp-server as a child process"
				}
			}
		}
	},
	"dependencies": {
		"sogo-db-core": "workspace:*"
	},
	"devDependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@tailwindcss/cli": "^4.0.0",
		"@tailwindcss/postcss": "^4.0.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.6",
		"@types/node": "^22.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/vscode": "^1.96.0",
		"esbuild": "^0.25.0",
		"marked": "^17.0.3",
		"postcss": "^8.5.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
